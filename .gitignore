# Atlas PC Support - .gitignore

# --- Datos de clientes / reportes ---
# NUNCA subir reportes generados, capturas, archivos de diagnóstico o fotos de equipos.
REPORTES_PC/
reportes/
reports/
logs/
*.log
*.bak
Reporte_*.txt
Reporte_*.html

# --- Binarios de terceros ---
# FastCopy, HWiNFO, CrystalDiskInfo, etc. se descargan en runtime, no van al repo.
bin/
dependencies/
*.exe
*.msi
*.zip
!assets/**/*.exe

# --- Configuración local del técnico ---
# branding.json es la config personalizada de CADA técnico. No subir.
# El repo trae branding.example.json como plantilla.
branding.json
branding.local.json
config/local/

# --- Artefactos de build (launcher compilado) ---
# launcher.ps1 SÍ se commitea al main branch porque es el entregable del irm|iex.
# Pero compile.log / temporales no.
compile.log
build-output.txt

# --- Sistema operativo ---
Thumbs.db
Desktop.ini
.DS_Store
*.swp
~*

# --- Editores ---
.vs/
.vscode/
*.suo
*.user
.idea/

# --- PowerShell ---
*.ps1xml.bak

# --- Fotos de leyenda / material gráfico personalizado ---
# Cada técnico pone la suya localmente.
assets/leyenda.*
assets/logo-custom.*
